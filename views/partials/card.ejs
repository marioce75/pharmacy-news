<%
  const catInfo = categories[article.category] || { label: article.category, color: '#888' };
  const dateStr = new Date(article.date_published + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
%>
<a href="/article/<%= article.slug %>" class="news-card">
  <% if (article.image) { %>
    <img class="news-card__image" src="<%= article.image %>" alt="" loading="lazy">
  <% } else { %>
    <div class="news-card__image" style="background:var(--bg-card-hover)"></div>
  <% } %>
  <div class="news-card__body">
    <div class="news-card__meta">
      <span class="news-card__tag" style="--tag-color: <%= catInfo.color %>"><%= catInfo.label %></span>
      <span class="news-card__dot"></span>
      <span class="news-card__source"><%= article.source %></span>
      <span class="news-card__dot"></span>
      <time><%= dateStr %></time>
    </div>
    <h2 class="news-card__title"><%= article.title %></h2>
    <p class="news-card__summary"><%= article.summary %></p>
  </div>
</a>
