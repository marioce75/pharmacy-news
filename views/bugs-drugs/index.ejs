<%- include('_head') %>
<body class="bd-body">
  <%- include('../partials/header', { activeCategory: 'bugs-drugs' }) %>
  <%- include('_gate') %>

  <section class="bd-hero">
    <div class="container">
      <h1>Bugs &amp; Drugs</h1>
      <p class="bd-hero__sub">Evidence-based empiric regimens by organism or syndrome, plus a renal-adjusted dose calculator. Sources: IDSA, CDC, FDA labels.</p>
      <%- include('_disclaimer') %>

      <div class="bd-search">
        <input type="search" id="bd-search-input" class="bd-search__input" placeholder="Search anything — bug, syndrome, or drug" autocomplete="off" autofocus>
        <ul id="bd-search-results" class="bd-search__results" role="listbox" aria-label="Search results"></ul>
      </div>
    </div>
  </section>

  <main class="container bd-main">
    <section class="bd-block">
      <h2 class="bd-block__title">Browse by syndrome</h2>
      <div class="bd-combo" data-kind="syndrome">
        <input type="search" class="bd-combo__input" placeholder="e.g. pneumonia, UTI, sepsis" autocomplete="off" aria-label="Search syndromes">
        <svg class="bd-combo__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 8 10 13 15 8"/></svg>
        <ul class="bd-combo__results" role="listbox" aria-label="Syndrome results"></ul>
      </div>
    </section>

    <section class="bd-block">
      <h2 class="bd-block__title">Browse by organism</h2>
      <div class="bd-combo" data-kind="organism">
        <input type="search" class="bd-combo__input" placeholder="e.g. MRSA, E. coli, Pseudomonas" autocomplete="off" aria-label="Search organisms">
        <svg class="bd-combo__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 8 10 13 15 8"/></svg>
        <ul class="bd-combo__results" role="listbox" aria-label="Organism results"></ul>
      </div>
    </section>

    <section class="bd-block">
      <h2 class="bd-block__title">Dose calculator — pick a drug</h2>
      <p class="bd-block__sub">Pick a drug to open its renal-adjusted dose calculator.</p>
      <div class="bd-combo" data-kind="drug">
        <input type="search" class="bd-combo__input" placeholder="e.g. vancomycin, meropenem, cefepime" autocomplete="off" aria-label="Search drugs">
        <svg class="bd-combo__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 8 10 13 15 8"/></svg>
        <ul class="bd-combo__results" role="listbox" aria-label="Drug results"></ul>
      </div>
    </section>
  </main>

  <% function gramLabel(gram) {
       if (gram === 'positive') return 'Gram-positive';
       if (gram === 'negative') return 'Gram-negative';
       if (gram === 'anaerobe') return 'Anaerobic';
       if (gram === 'atypical' || gram === 'spirochete') return 'Atypical / intracellular';
       if (gram === 'afb') return 'Mycobacteria';
       if (gram === 'fungus') return 'Fungi';
       if (gram === 'virus') return 'Viruses';
       return 'Other';
     } %>
  <script id="bd-combo-data" type="application/json">
    <%- JSON.stringify({
      syndrome: syndromes.map(s => ({ slug: s.slug, label: s.name, sub: '' })),
      organism: organisms.map(o => ({
        slug: o.slug,
        label: o.name,
        sub: (o.full_name && o.full_name !== o.name) ? o.full_name : '',
        group: gramLabel(o.gram)
      })),
      drug: Object.values(drugs).map(d => ({ slug: d.slug, label: d.generic, sub: d.class || '' }))
    }) %>
  </script>

  <%- include('../partials/footer') %>
  <script src="/js/bugs-drugs.js"></script>
</body>
</html>
