<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics — Pharmacy News Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/admin.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
</head>
<body class="admin-body">
  <div class="admin-layout">
    <%- include('_sidebar', { page: 'analytics', totalPending: 0 }) %>
    <main class="admin-main">
      <div class="admin-header">
        <h1>Analytics</h1>
      </div>

      <div class="stats-cards">
        <div class="stat-card">
          <div class="stat-value" style="color:var(--signal-green)"><%= stats.counts.approved %></div>
          <div class="stat-label">Published</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#F59E0B"><%= stats.counts.pending %></div>
          <div class="stat-label">Pending</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#EF4444"><%= stats.counts.declined %></div>
          <div class="stat-label">Declined</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#3B82F6"><%= (stats.approvalRate * 100).toFixed(0) %>%</div>
          <div class="stat-label">Approval Rate</div>
        </div>
      </div>

      <div class="charts-grid">
        <div class="chart-container">
          <h3>Articles by Category</h3>
          <canvas id="categoryChart"></canvas>
        </div>
        <div class="chart-container">
          <h3>Approval Rate</h3>
          <canvas id="approvalChart"></canvas>
        </div>
      </div>

      <div class="charts-grid">
        <div class="chart-container">
          <h3>Top Sources</h3>
          <table class="admin-table">
            <thead>
              <tr><th>Source</th><th>Articles</th></tr>
            </thead>
            <tbody>
              <% stats.topSources.forEach(s => { %>
                <tr><td><%= s.source %></td><td><%= s.count %></td></tr>
              <% }); %>
              <% if (stats.topSources.length === 0) { %>
                <tr><td colspan="2" style="color:var(--text-dim)">No data yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <div class="chart-container">
          <h3>Top Therapeutic Areas</h3>
          <table class="admin-table">
            <thead>
              <tr><th>Area</th><th>Articles</th></tr>
            </thead>
            <tbody>
              <% stats.topAreas.forEach(a => { %>
                <tr><td><%= a.area %></td><td><%= a.count %></td></tr>
              <% }); %>
              <% if (stats.topAreas.length === 0) { %>
                <tr><td colspan="2" style="color:var(--text-dim)">No data yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
  <script>
    const stats = <%- JSON.stringify(stats) %>;
    const catConfig = <%- JSON.stringify(categories) %>;

    // Category chart
    const catLabels = Object.keys(stats.byCategory);
    const catColors = catLabels.map(k => catConfig[k]?.color || '#888');
    new Chart(document.getElementById('categoryChart'), {
      type: 'bar',
      data: {
        labels: catLabels.map(k => catConfig[k]?.label || k),
        datasets: [
          { label: 'Approved', data: catLabels.map(k => stats.byCategory[k]?.approved || 0), backgroundColor: catColors.map(c => c + '99') },
          { label: 'Pending', data: catLabels.map(k => stats.byCategory[k]?.pending || 0), backgroundColor: catColors.map(c => c + '44') }
        ]
      },
      options: {
        responsive: true,
        scales: {
          x: { ticks: { color: '#8a96a3', font: { size: 10 } }, grid: { color: '#1e2830' } },
          y: { ticks: { color: '#8a96a3' }, grid: { color: '#1e2830' } }
        },
        plugins: { legend: { labels: { color: '#8a96a3' } } }
      }
    });

    // Approval rate chart
    new Chart(document.getElementById('approvalChart'), {
      type: 'doughnut',
      data: {
        labels: ['Approved', 'Declined', 'Pending'],
        datasets: [{
          data: [stats.counts.approved, stats.counts.declined, stats.counts.pending],
          backgroundColor: ['#00d4aa', '#EF4444', '#F59E0B']
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { labels: { color: '#8a96a3' } } }
      }
    });
  </script>
  <script src="/js/admin.js"></script>
</body>
</html>
