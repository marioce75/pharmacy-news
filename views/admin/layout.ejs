<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Pharmacy News</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/admin.css">
  <% if (typeof extraHead !== 'undefined') { %><%- extraHead %><% } %>
</head>
<body class="admin-body">
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <a href="/" class="admin-brand">
        <span class="logo-dosys">Dosys</span>
        <span style="color:var(--text-muted);font-size:0.75rem">Admin</span>
      </a>
      <nav class="admin-nav">
        <a href="/admin/queue" class="admin-nav-link<%= page === 'queue' ? ' active' : '' %>">
          <span>Review Queue</span>
          <% if (typeof totalPending !== 'undefined' && totalPending > 0) { %>
            <span class="badge"><%= totalPending %></span>
          <% } %>
        </a>
        <a href="/admin/published" class="admin-nav-link<%= page === 'published' ? ' active' : '' %>">Published</a>
        <a href="/admin/analytics" class="admin-nav-link<%= page === 'analytics' ? ' active' : '' %>">Analytics</a>
        <a href="/admin/settings" class="admin-nav-link<%= page === 'settings' ? ' active' : '' %>">Settings</a>
      </nav>
      <div class="admin-sidebar-footer">
        <a href="/" class="admin-nav-link">← Public Site</a>
        <a href="/admin/logout" class="admin-nav-link">Logout</a>
      </div>
    </aside>
    <main class="admin-main">
      <%- body %>
    </main>
  </div>
  <script src="/js/admin.js"></script>
</body>
</html>
