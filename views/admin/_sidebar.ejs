    <a href="/admin/analytics" class="admin-nav-link<%= page === 'analytics' ? ' active' : '' %>">Analytics</a>
    <a href="/admin/logs" class="admin-nav-link<%= page === 'logs' ? ' active' : '' %>">Scrape Logs</a>
    <a href="/admin/settings" class="admin-nav-link<%= page === 'settings' ? ' active' : '' %>">Settings</a>
  </nav>
  <div class="admin-sidebar-footer">
