  <a href="/" class="admin-brand">
    <span class="logo-dosys">Dosys</span>
    <span style="color:var(--text-muted);font-size:0.75rem">Admin</span>
  </a>
  <nav class="admin-nav">
    <a href="/admin" class="admin-nav-link<%= page === 'dashboard' ? ' active' : '' %>">Dashboard</a>
